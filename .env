

# Demo App version
IMAGE_VERSION=latest
IMAGE_NAME=clickhouse/ch-otel-demo
DEMO_VERSION=latest

# Build Args
TRACETEST_IMAGE_VERSION=v1.7.1
OTEL_JAVA_AGENT_VERSION=2.13.3
OPENTELEMETRY_CPP_VERSION=1.19.0

# Dependent images
COLLECTOR_CONTRIB_IMAGE=ghcr.io/open-telemetry/opentelemetry-collector-releases/opentelemetry-collector-contrib:0.120.0
FLAGD_IMAGE=ghcr.io/open-feature/flagd:v0.12.1
GRAFANA_IMAGE=grafana/grafana:11.5.2
JAEGERTRACING_IMAGE=jaegertracing/all-in-one:1.66.0
# must also update version field in src/grafana/provisioning/datasources/opensearch.yaml
OPENSEARCH_IMAGE=opensearchproject/opensearch:2.19.0
POSTGRES_IMAGE=postgres:17.3
PROMETHEUS_IMAGE=quay.io/prometheus/prometheus:v3.2.0
VALKEY_IMAGE=valkey/valkey:8.1-alpine
TRACETEST_IMAGE=kubeshop/tracetest:${TRACETEST_IMAGE_VERSION}

# Demo Platform
ENV_PLATFORM=local

# OpenTelemetry Collector
HOST_FILESYSTEM=/
DOCKER_SOCK=/var/run/docker.sock
OTEL_COLLECTOR_HOST=otel-collector
OTEL_COLLECTOR_PORT_GRPC=4317
OTEL_COLLECTOR_PORT_HTTP=4318
OTEL_COLLECTOR_CONFIG=./src/otel-collector/otelcol-config.yml
OTEL_COLLECTOR_CONFIG_EXTRAS=./src/otel-collector/otelcol-config-extras.yml
OTEL_EXPORTER_OTLP_ENDPOINT=http://${OTEL_COLLECTOR_HOST}:${OTEL_COLLECTOR_PORT_GRPC}
PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT=http://${OTEL_COLLECTOR_HOST}:${OTEL_COLLECTOR_PORT_HTTP}
PUBLIC_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:8080/otlp-http/v1/traces

# OpenTelemetry Resource Definitions
OTEL_RESOURCE_ATTRIBUTES="service.namespace=opentelemetry-demo,service.version=${IMAGE_VERSION},deployment.environment=staging,deployment.environment.name=staging-us-east-1,cloud.provider=aws,cloud.region=us-east-1,cloud.availability_zone=us-east-1a,cloud.account.id=123456789012,cloud.platform=aws_ecs,cloud.resource_id=arn:aws:ecs:us-east-1:123456789012:task/otel-demo/abc123def456,k8s.cluster.name=otel-demo-prod-useast1,k8s.cluster.uid=a1b2c3d4-e5f6-7890-abcd-ef1234567890,k8s.namespace.name=opentelemetry-demo,k8s.node.name=ip-10-0-42-217.ec2.internal,k8s.node.uid=node-uid-98765,host.name=ip-10-0-42-217.ec2.internal,host.id=i-0a1b2c3d4e5f67890,host.type=m5.xlarge,host.arch=amd64,host.image.name=amazon-linux-2023,host.image.id=ami-0abcdef1234567890,host.image.version=2023.4.20261201,os.type=linux,os.description=Amazon Linux 2023,os.name=Amazon Linux,os.version=2023,process.runtime.name=various,process.runtime.version=various,container.runtime=containerd,container.image.repo_digests=sha256:abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890,telemetry.distro.name=opentelemetry,telemetry.distro.version=1.4.0,service.team=platform-engineering,service.tier=tier-1,service.component=ecommerce,organization.name=AcmeCorp,organization.unit=retail-platform,organization.cost_center=CC-4521,environment.region=us-east-1,environment.datacenter=use1-az1,environment.cluster_size=medium,network.vpc_id=vpc-0abc123def456789,network.subnet_id=subnet-0abc123def456789"

# Metrics Temporality
OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=cumulative

# ******************
# Core Demo Services
# ******************
# Accounting Service
ACCOUNTING_DOCKERFILE=./src/accounting/Dockerfile

# Ad Service
AD_PORT=9555
AD_ADDR=ad:${AD_PORT}
AD_DOCKERFILE=./src/ad/Dockerfile

# Cart Service
CART_PORT=7070
CART_ADDR=cart:${CART_PORT}
CART_DOCKERFILE=./src/cart/src/Dockerfile

# Checkout Service
CHECKOUT_PORT=5050
CHECKOUT_ADDR=checkout:${CHECKOUT_PORT}
CHECKOUT_DOCKERFILE=./src/checkout/Dockerfile

# Currency Service
CURRENCY_PORT=7001
CURRENCY_ADDR=currency:${CURRENCY_PORT}
CURRENCY_DOCKERFILE=./src/currency/Dockerfile

# Email Service
EMAIL_PORT=6060
EMAIL_ADDR=http://email:${EMAIL_PORT}
EMAIL_DOCKERFILE=./src/email/Dockerfile

# Fraud Service
FRAUD_DOCKERFILE=./src/fraud-detection/Dockerfile

# Frontend
FRONTEND_PORT=8080
FRONTEND_ADDR=frontend:${FRONTEND_PORT}
FRONTEND_DOCKERFILE=./src/frontend/Dockerfile
IMAGE_BASE_URL=https://oteldemo.s3.eu-west-3.amazonaws.com

# Frontend Proxy (Envoy)
FRONTEND_HOST=frontend
ENVOY_PORT=8080
FRONTEND_PROXY_ADDR=frontend-proxy:${ENVOY_PORT}
FRONTEND_PROXY_DOCKERFILE=./src/frontend-proxy/Dockerfile

# Image Provider
IMAGE_PROVIDER_HOST=image-provider
IMAGE_PROVIDER_PORT=8081
IMAGE_PROVIDER_DOCKERFILE=./src/image-provider/Dockerfile

# Load Generator
LOCUST_WEB_PORT=8089
LOCUST_USERS=5
LOCUST_HOST=http://${FRONTEND_PROXY_ADDR}
LOCUST_WEB_HOST=load-generator
LOCUST_AUTOSTART=true
LOCUST_HEADLESS=false
LOAD_GENERATOR_DOCKERFILE=./src/load-generator/Dockerfile

# Payment Service
PAYMENT_PORT=50051
PAYMENT_ADDR=payment:${PAYMENT_PORT}
PAYMENT_DOCKERFILE=./src/payment/Dockerfile

# Product Catalog Service
PRODUCT_CATALOG_RELOAD_INTERVAL=10
PRODUCT_CATALOG_PORT=3550
PRODUCT_CATALOG_ADDR=product-catalog:${PRODUCT_CATALOG_PORT}
PRODUCT_CATALOG_DOCKERFILE=./src/product-catalog/Dockerfile

# Quote Service
QUOTE_PORT=8090
QUOTE_ADDR=http://quote:${QUOTE_PORT}
QUOTE_DOCKERFILE=./src/quote/Dockerfile

# Recommendation Service
RECOMMENDATION_PORT=9001
RECOMMENDATION_ADDR=recommendation:${RECOMMENDATION_PORT}
RECOMMENDATION_DOCKERFILE=./src/recommendation/Dockerfile

# Shipping Service
SHIPPING_PORT=50050
SHIPPING_ADDR=shipping:${SHIPPING_PORT}
SHIPPING_DOCKERFILE=./src/shipping/Dockerfile

# ******************
# Dependent Services
# ******************
# Flagd
FLAGD_HOST=flagd
FLAGD_PORT=8013
FLAGD_OFREP_PORT=8016

# Flagd UI
FLAGD_UI_HOST=flagd-ui
FLAGD_UI_PORT=4000
FLAGD_UI_DOCKERFILE=./src/flagd-ui/Dockerfile

# Kafka
KAFKA_PORT=9092
KAFKA_ADDR=kafka:${KAFKA_PORT}
KAFKA_DOCKERFILE=./src/kafka/Dockerfile

# Valkey
VALKEY_PORT=6379
VALKEY_ADDR=valkey-cart:${VALKEY_PORT}

# ********************
# Telemetry Components
# ********************
# Grafana
GRAFANA_PORT=3000
GRAFANA_HOST=grafana

# Used by docker-compose.yml
IMAGE_NAME_DOCKERHUB=hyperdx/hyperdx
IMAGE_NAME_HDX=docker.hyperdx.io/hyperdx/hyperdx
OTEL_COLLECTOR_HYPERDX_IMAGE_NAME=ghcr.io/hyperdxio/hyperdx-otel-collector
OTEL_COLLECTOR_HYPERDX_IMAGE_NAME_DOCKERHUB=hyperdx/hyperdx-otel-collector
IMAGE_HYPERDX_VERSION=2

# Set up domain URLs
HYPERDX_API_PORT=8000 #optional (should not be taken by other services)
HYPERDX_APP_PORT=9080
HYPERDX_APP_URL=http://localhost
HYPERDX_LOG_LEVEL=debug

# TEMPORARY: local development
HYPERDX_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
